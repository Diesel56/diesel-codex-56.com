# EditorConfig for cross-editor consistency
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# JavaScript/TypeScript files
[*.{js,jsx,ts,tsx}]
indent_size = 2
quote_type = single

# HTML/CSS files
[*.{html,css,scss,sass,less}]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# Batch files (Windows)
[*.{bat,cmd}]
end_of_line = crlf
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Makefiles
[Makefile]
indent_style = tab

# Git config files
[.git*]
indent_size = 2

# VS Code settings
[.vscode/*.json]
indent_size = 2

# Cursor settings
[.cursor/*.json]
indent_size = 2