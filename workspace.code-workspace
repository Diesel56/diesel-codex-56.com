{
  "folders": [
    {
      "name": "Diesel Engine Root",
      "path": "."
    },
    {
      "name": "Diesel Codex",
      "path": "Diesel-Codex-56"
    }
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    "editor.rulers": [80, 120],
    "editor.wordWrap": "on",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "python.linting.enabled": true,
    "python.formatting.provider": "black",
    
    "terminal.integrated.env.windows": {
      "GENESIS_CLI_HOME": "${workspaceFolder}",
      "DIESEL_ENGINE_PATH": "${workspaceFolder}/diesel_engine.yaml",
      "PYTHONPATH": "${workspaceFolder}"
    },
    "terminal.integrated.env.linux": {
      "GENESIS_CLI_HOME": "${workspaceFolder}",
      "DIESEL_ENGINE_PATH": "${workspaceFolder}/diesel_engine.yaml",
      "PYTHONPATH": "${workspaceFolder}"
    },
    "terminal.integrated.env.osx": {
      "GENESIS_CLI_HOME": "${workspaceFolder}",
      "DIESEL_ENGINE_PATH": "${workspaceFolder}/diesel_engine.yaml",
      "PYTHONPATH": "${workspaceFolder}"
    },
    
    "cursor.aiEnabled": true,
    "cursor.cpp.enabled": true,
    "claude.model": "claude-3-opus-20240229",
    
    "genesis.cli.path": "${workspaceFolder}/genesis-cli",
    "genesis.cli.autoDetect": true,
    "diesel.engine.configPath": "${workspaceFolder}/diesel_engine.yaml",
    "diesel.engine.autoLoad": true
  },
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "ms-python.black-formatter",
      "esbenp.prettier-vscode",
      "redhat.vscode-yaml",
      "github.copilot",
      "continue.continue",
      "anthropic.claude-dev",
      "cursor-ai.cursor-ai"
    ]
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Python: Diesel Agent",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/diesel-agent.py",
        "console": "integratedTerminal",
        "env": {
          "PYTHONPATH": "${workspaceFolder}",
          "DIESEL_ENGINE_CONFIG": "${workspaceFolder}/diesel_engine.yaml"
        }
      },
      {
        "name": "Node.js: Resonance",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/Diesel-Codex-56/resonance-core.js"
      }
    ],
    "compounds": [
      {
        "name": "Full Stack",
        "configurations": ["Python: Diesel Agent", "Node.js: Resonance"]
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Genesis: Build",
        "type": "shell",
        "command": "./genesis",
        "args": ["build"],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": ["$python"]
      },
      {
        "label": "Genesis: Deploy",
        "type": "shell",
        "command": "./genesis",
        "args": ["deploy"],
        "group": "none",
        "problemMatcher": []
      },
      {
        "label": "Run Tests",
        "type": "shell",
        "command": "python",
        "args": ["-m", "pytest", "-v"],
        "group": "test",
        "problemMatcher": ["$python"]
      }
    ]
  }
}