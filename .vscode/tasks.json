{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Python Dependencies",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "windows": {
        "command": "${env:PYTHON_HOME}\\python.exe",
        "args": ["-m", "pip", "install", "-r", "requirements.txt"]
      },
      "linux": {
        "command": "python3"
      }
    },
    {
      "label": "Create Virtual Environment",
      "type": "shell",
      "command": "python",
      "args": ["-m", "venv", ".venv"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": [],
      "windows": {
        "command": "python"
      },
      "linux": {
        "command": "python3"
      }
    },
    {
      "label": "Run Diesel Agent",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["${workspaceFolder}/diesel-agent.py"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "dependsOn": ["Install Python Dependencies"]
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["-m", "pytest", "-v", "--tb=short"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$python"]
    },
    {
      "label": "Format Python Code",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["-m", "black", "${workspaceFolder}", "--line-length", "88"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint Python Code",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["-m", "flake8", "${workspaceFolder}", "--max-line-length", "88"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$flake8"]
    },
    {
      "label": "Type Check Python Code",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["-m", "mypy", "${workspaceFolder}"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$mypy"]
    },
    {
      "label": "Deploy to Production",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["${workspaceFolder}/deploy.py"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Secure Deploy",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["${workspaceFolder}/secure_deploy.py"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Live Server",
      "type": "shell",
      "command": "python",
      "args": ["-m", "http.server", "8080"],
      "isBackground": true,
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "windows": {
        "command": "python"
      },
      "linux": {
        "command": "python3"
      }
    },
    {
      "label": "Genesis CLI: Init",
      "type": "shell",
      "command": "genesis",
      "args": ["init"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Genesis CLI: Build",
      "type": "shell",
      "command": "genesis",
      "args": ["build", "--config", "${workspaceFolder}/diesel_engine.yaml"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Genesis CLI: Deploy",
      "type": "shell",
      "command": "genesis",
      "args": ["deploy", "--env", "production"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: Commit",
      "type": "shell",
      "command": "git",
      "args": ["commit", "-m", "\"${input:commitMessage}\""],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: Push",
      "type": "shell",
      "command": "git",
      "args": ["push", "origin", "HEAD"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Enter commit message",
      "default": "Update"
    }
  ]
}